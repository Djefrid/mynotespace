# Firebase (current)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_ADMIN_EMAIL=
NEXT_PUBLIC_ADMIN_EMAIL_2=
NEXT_PUBLIC_SITE_URL=

# PostgreSQL — Neon (serverless Postgres via Vercel)
DATABASE_URL=              # URL poolée (pgbouncer) — utilisée par le runtime Next.js
DATABASE_URL_UNPOOLED=     # URL directe — utilisée par prisma db push/migrate uniquement
AUTH_SECRET=                  # générer avec : npx auth secret
# Auth.js v5 : AUTH_URL remplace NEXTAUTH_URL. En production Vercel, AUTH_URL n'est pas
# nécessaire si trustHost: true est configuré (détection automatique via x-forwarded-host).
# En local uniquement :
AUTH_URL=http://localhost:3000
AUTH_GOOGLE_ID=               # Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID
AUTH_GOOGLE_SECRET=           # Secret correspondant
R2_ACCOUNT_ID=               # ID de compte Cloudflare (visible dans l'URL du dashboard)
R2_ACCESS_KEY_ID=            # Clé d'accès générée dans R2 → Manage R2 API tokens
R2_SECRET_ACCESS_KEY=        # Secret correspondant
R2_BUCKET_NAME=              # Nom du bucket (ex: mynotespace)
R2_PUBLIC_URL=               # Domaine custom ou dev URL (ex: https://assets.djefrid.ca)
MAX_UPLOAD_BYTES=            # Optionnel — défaut 10485760 (10 MB)
TYPESENSE_HOST=               # ex: abc123.typesense.net (sans https://, sans port)
TYPESENSE_API_KEY=            # Clé admin ou clé avec scope search+write sur la collection "notes"
UPSTASH_REDIS_REST_URL=       # ex: https://xxx-xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=    # Token read-write du cluster Upstash
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Migration Firestore → PostgreSQL (script scripts/migrate-firestore-to-postgres.ts)
MIGRATION_FIREBASE_SA_PATH=        # Chemin vers le JSON service account Firebase
                                   # ex: ./service-account.json (NE PAS committer ce fichier)
                                   # Firebase Console → Project Settings → Service accounts → Generate new private key
MIGRATION_USER_EMAIL=              # Optionnel — défaut: djefridbyli@gmail.com
